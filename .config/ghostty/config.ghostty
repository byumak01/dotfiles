# Portable baseline for Linux, macOS, and Windows.
# Keep font and shell unset so Ghostty can use good platform defaults.

theme = Ghostty Default Style Dark

window-padding-x = 4
window-padding-y = 2
window-padding-balance = true

copy-on-select = clipboard
clipboard-read = ask
clipboard-write = allow
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Makes Option behave like Alt on macOS, useful for tmux/vim Alt bindings.
macos-option-as-alt = true
